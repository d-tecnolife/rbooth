{{ define "board" }}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body>
<button class="menu-scrim" type="button" data-nav-scrim aria-label="Close menu"></button>
<aside class="side-menu" aria-label="Site menu">
  <div class="side-menu-head">
    <div class="brand-block">
      <div class="brand-mark">rb</div>
      <div class="brand-copy">
        <strong>rbooth</strong>
        <span>photo board</span>
      </div>
    </div>
    <button type="button" data-nav-close>Close</button>
  </div>
  <div class="side-menu-links">
    <a class="nav-link nav-link-active" href="{{ .BoardURL }}">Photo board</a>
    <a class="nav-link" href="{{ .JoinURL }}">Take a photo</a>
    <a class="nav-link" href="{{ .AdminURL }}">Host tools</a>
  </div>
  <div class="side-menu-meta">
    <div class="menu-note">The board is the focus here, so the navigation lives off-canvas and the wall gets the screen first.</div>
  </div>
</aside>

<main class="shell shell-board">
  <nav class="site-nav" aria-label="Primary">
    <div class="brand-block">
      <div class="brand-mark">rb</div>
      <div class="brand-copy">
        <strong>rbooth</strong>
        <span>live photo wall</span>
      </div>
    </div>
    <button class="nav-toggle" type="button" data-nav-open>Menu</button>
  </nav>

  <section class="board-shell">
    <div class="board-main">
      <div class="pinboard-frame">
        <div class="pinboard-header">
          <span>Moments pinned up</span>
          <span>{{ len .Photos }} prints on the wall</span>
        </div>
        <div id="boardGrid" class="board-grid">
        {{ range .Photos }}
        <article class="photo-card">
          <img src="{{ .DisplayURL }}" alt="{{ .Caption }}">
          <div class="photo-meta">
            <strong>{{ if .Caption }}{{ .Caption }}{{ else }}Fresh upload{{ end }}</strong>
            <span>{{ .CreatedAt.Format "15:04:05 UTC" }}</span>
          </div>
        </article>
        {{ else }}
        <article class="photo-card photo-card-empty">
          <div class="photo-meta">
            <strong>The board is ready</strong>
            <span>New snapshots will pin themselves here and stack into the collage live.</span>
          </div>
        </article>
        {{ end }}
        </div>
      </div>

      <section class="board-topbar">
        <div class="board-topbar-copy">
          <p class="eyebrow">Live memory board</p>
          <h1 class="compact-title">A pinned-photo wall, not a text-heavy landing page.</h1>
          <p>Guests scan, snap, and publish. The board keeps building live like a real corkboard of prints.</p>
        </div>
        <div class="mini-chips">
          <span>Live updates</span>
          <span>Real-board feel</span>
          <span>Shared screen ready</span>
        </div>
      </section>
    </div>

    <aside class="board-rail">
      <div>
        <p class="eyebrow">Quick join</p>
        <img class="board-mini-qr" src="/qr" alt="QR code for joining the booth">
      </div>
      <div class="board-note">
        <h2>Guest flow</h2>
        <p>Scan the code, take or upload a photo, then publish it straight onto the wall.</p>
      </div>
      <div class="board-links">
        <a href="{{ .JoinURL }}">Open camera page</a>
        <a href="{{ .AdminURL }}">Show host tools</a>
      </div>
    </aside>
  </section>
</main>

<script src="/static/js/nav.js" defer></script>
<script src="/static/js/board.js" defer></script>
</body>
</html>
{{ end }}
