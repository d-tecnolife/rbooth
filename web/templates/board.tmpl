{{ define "board" }}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <link rel="stylesheet" href="/static/css/app.css?v=20260325a">
</head>
<body>
<button class="menu-scrim" type="button" data-nav-scrim aria-label="close menu"></button>
<aside class="side-menu" aria-label="site menu">
  <div class="side-menu-head">
    <div class="brand-block">
      <div class="brand-mark" aria-hidden="true">&#9829;</div>
      <div class="brand-copy">
        <strong>{{ .AppName }}</strong>
        <span>{{ .Personalization.AppSubtitle }}</span>
      </div>
    </div>
    <button type="button" data-nav-close>close</button>
  </div>
  <div class="side-menu-links">
    <a class="nav-link" href="/">home</a>
    <a class="nav-link nav-link-active" href="{{ .BoardURL }}">photo wall</a>
    <a class="nav-link" href="{{ .CaptureURL }}">take a photo</a>
  </div>
</aside>

<main class="shell shell-board">
  <nav class="site-nav" aria-label="primary">
    <div class="brand-block">
      <div class="brand-mark" aria-hidden="true">&#9829;</div>
      <div class="brand-copy">
        <strong>{{ .AppName }}</strong>
        <span>live photo wall</span>
      </div>
    </div>
    <button class="nav-toggle" type="button" data-nav-open>menu</button>
  </nav>

  <section class="board-shell">
    <div class="board-main">
      <div class="pinboard-frame">
        <div class="pinboard-header">
          <span id="boardCount">{{ len .Photos }} photos pinned on the wall</span>
        </div>
        <div id="boardGrid" class="board-grid" data-empty-title="{{ .Personalization.BoardEmptyTitle }}" data-empty-body="{{ .Personalization.BoardEmptyBody }}">
        {{ range .Photos }}
        <article class="photo-card" data-photo-id="{{ .ID }}">
          <img src="{{ .DisplayURL }}" alt="{{ .Caption }}">
          <div class="photo-meta">
            <strong class="photo-caption">{{ .Caption }}</strong>
            <span>{{ .CreatedAt.Format "15:04:05 UTC" }}</span>
          </div>
        </article>
        {{ else }}
        <article class="photo-card photo-card-empty">
          <div class="photo-meta">
            <strong>{{ .Personalization.BoardEmptyTitle }}</strong>
            <span>{{ .Personalization.BoardEmptyBody }}</span>
          </div>
        </article>
        {{ end }}
        </div>
      </div>
    </div>
  </section>
</main>

<script src="/static/js/nav.js?v=20260325a" defer></script>
<script src="/static/js/board.js?v=20260325a" defer></script>
</body>
</html>
{{ end }}
