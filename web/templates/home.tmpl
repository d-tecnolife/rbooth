{{ define "home" }}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <link rel="stylesheet" href="/static/css/app.css?v=20260325a">
</head>
<body>
<button class="menu-scrim" type="button" data-nav-scrim aria-label="close menu"></button>
<aside class="side-menu" aria-label="site menu">
  <div class="side-menu-head">
    <div class="brand-block">
      <div class="brand-mark" aria-hidden="true">&#9829;</div>
      <div class="brand-copy">
        <strong>{{ .AppName }}</strong>
        <span>{{ .Personalization.AppSubtitle }}</span>
      </div>
    </div>
    <button type="button" data-nav-close>close</button>
  </div>
  <div class="side-menu-links">
    <a class="nav-link nav-link-active" href="/">home</a>
    <a class="nav-link" href="{{ .BoardURL }}">photo wall</a>
    <a class="nav-link" href="{{ .CaptureURL }}">take a photo</a>
  </div>
</aside>

<main class="shell shell-board">
  <nav class="site-nav" aria-label="primary">
    <div class="brand-block">
      <div class="brand-mark" aria-hidden="true">&#9829;</div>
      <div class="brand-copy">
        <strong>{{ .AppName }}</strong>
        <span>{{ .Personalization.AppSubtitle }}</span>
      </div>
    </div>
    <button class="nav-toggle" type="button" data-nav-open>menu</button>
  </nav>

  <section class="compact-panel">
    <div class="notfound-panel">
      <div class="notfound-copy">
        <p class="eyebrow">welcome</p>
        <h1 class="compact-title">{{ .Personalization.HomeWelcomeTitle }}</h1>
        <p class="compact-copy">{{ .Personalization.HomeWelcomeBody }}</p>
      </div>
    </div>
  </section>

  <section class="compact-panel">
    <div class="board-rail">
      <div>
        <p class="eyebrow">private access</p>
        <h2>{{ .Personalization.HomeAccessTitle }}</h2>
        <p class="compact-copy">{{ .Personalization.HomeAccessBody }}</p>
      </div>
      <div class="board-note">
        <h2>how to pin a photo</h2>
        <p>1. scan the qr code with your phone.</p>
        <p>2. the capture page opens on your phone.</p>
        <p>3. take or upload a photo.</p>
        <p>4. make any edits like setting a caption, setting a frame, or setting a background.</p>
        <p>5. pin it to the wall.</p>
      </div>
    </div>
  </section>
</main>

<script src="/static/js/nav.js?v=20260325a" defer></script>
</body>
</html>
{{ end }}
