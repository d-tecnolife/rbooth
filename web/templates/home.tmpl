{{ define "home" }}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body>
<button class="menu-scrim" type="button" data-nav-scrim aria-label="Close menu"></button>
<aside class="side-menu" aria-label="Site menu">
  <div class="side-menu-head">
    <div class="brand-block">
      <div class="brand-mark">rb</div>
      <div class="brand-copy">
        <strong>rbooth</strong>
        <span>shared booth</span>
      </div>
    </div>
    <button type="button" data-nav-close>Close</button>
  </div>
  <div class="side-menu-links">
    <a class="nav-link nav-link-active" href="/">Home</a>
    <a class="nav-link" href="{{ .BoardURL }}">Photo wall</a>
    <a class="nav-link" href="{{ .CaptureURL }}">Take a photo</a>
  </div>
  <div class="side-menu-meta">
    <div class="menu-note">Home, photo wall, and camera stay in the same menu.</div>
  </div>
</aside>

<main class="shell shell-board">
  <nav class="site-nav" aria-label="Primary">
    <div class="brand-block">
      <div class="brand-mark">rb</div>
      <div class="brand-copy">
        <strong>rbooth</strong>
        <span>photo booth</span>
      </div>
    </div>
    <button class="nav-toggle" type="button" data-nav-open>Menu</button>
  </nav>

  <section class="compact-panel">
    <div class="notfound-panel">
      <div class="notfound-copy">
        <p class="eyebrow">Welcome</p>
        <h1 class="compact-title">Placeholder welcome message.</h1>
        <p class="compact-copy">This is where the custom welcome message will go.</p>
      </div>
    </div>
  </section>

  <section class="compact-panel">
    <div class="board-rail">
      <div>
        <p class="eyebrow">Private access</p>
        <h2>Use the booth QR code to enter.</h2>
        <p class="compact-copy">The capture and board pages only open after the signed QR link sets your access cookie.</p>
      </div>
      <div class="board-note">
        <h2>How to pin a photo</h2>
        <p>1. Scan the QR code on the booth display.</p>
        <p>2. Open the capture page on your phone.</p>
        <p>3. Take or upload a photo.</p>
        <p>4. Pin it to the board.</p>
      </div>
    </div>
  </section>
</main>

<script src="/static/js/nav.js" defer></script>
</body>
</html>
{{ end }}
