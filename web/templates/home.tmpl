{{ define "home" }}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body>
<button class="menu-scrim" type="button" data-nav-scrim aria-label="Close menu"></button>
<aside class="side-menu" aria-label="Site menu">
  <div class="side-menu-head">
    <div class="brand-block">
      <div class="brand-mark">rb</div>
      <div class="brand-copy">
        <strong>rbooth</strong>
        <span>photo booth</span>
      </div>
    </div>
    <button type="button" data-nav-close>Close</button>
  </div>
  <div class="side-menu-links">
    <a class="nav-link" href="/">Photo board</a>
    <a class="nav-link" href="/join">Take a photo</a>
    <a class="nav-link" href="/admin">Host tools</a>
  </div>
  <div class="side-menu-meta">
    <div class="menu-note">Navigation lives in a side panel so the main site layout stays cleaner and more screen-efficient.</div>
  </div>
</aside>

<main class="shell shell-home">
  <nav class="site-nav" aria-label="Primary">
    <div class="brand-block">
      <div class="brand-mark">rb</div>
      <div class="brand-copy">
        <strong>rbooth</strong>
        <span>pastel photo booth</span>
      </div>
    </div>
    <button class="nav-toggle" type="button" data-nav-open>Menu</button>
  </nav>

  <section class="compact-panel">
    <div class="home-grid">
      <div>
        <p class="eyebrow">Browser-only photo booth</p>
        <h1 class="compact-title">A lighter intro. The board should do the talking.</h1>
        <p class="compact-copy">Create a booth, open the live board on a shared screen, and let guests join instantly from their phones.</p>
      </div>
      <form class="card create-form" method="post" action="/events">
        <label for="code">Event code</label>
        <div class="row">
          <input id="code" name="code" type="text" value="{{ .DefaultCode }}" maxlength="24" autocomplete="off">
          <button type="submit">Create booth</button>
        </div>
        <p class="hint">Use letters, numbers, and dashes only.</p>
      </form>
    </div>
  </section>

  <section class="event-list">
    <div class="section-head">
      <h2>Recent events</h2>
      <a class="nav-link" href="/admin/demo">Open demo</a>
    </div>

    {{ if .Events }}
    <div class="grid cards">
      {{ range .Events }}
      <article class="card event-card">
        <h3>{{ .Code }}</h3>
        <p>Created {{ .CreatedAt.Format "2006-01-02 15:04 UTC" }}</p>
        <div class="actions">
          <a class="nav-link" href="/admin/{{ .Code }}">Admin</a>
          <a class="nav-link" href="/join/{{ .Code }}">Join</a>
          <a class="nav-link" href="/board/{{ .Code }}">Board</a>
        </div>
      </article>
      {{ end }}
    </div>
    {{ else }}
    <p class="card empty">No events yet.</p>
    {{ end }}
  </section>
</main>

<script src="/static/js/nav.js" defer></script>
</body>
</html>
{{ end }}
