{{ define "home" }}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body>
<main class="shell shell-home">
  <nav class="site-nav" aria-label="Primary">
    <div class="brand-block">
      <div class="brand-mark">rb</div>
      <div class="brand-copy">
        <strong>rbooth</strong>
        <span>girly pastel photo booth</span>
      </div>
    </div>
    <div class="nav-links">
      <a class="nav-link" href="/">Photo board</a>
      <a class="nav-link" href="/join">Take a photo</a>
      <a class="nav-link" href="/admin">Host tools</a>
    </div>
  </nav>

  <section class="hero-panel">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Browser-only photo booth</p>
        <h1>A pastel photo booth that feels party-ready.</h1>
        <p>Create a booth, open the live board on a shared screen, and let guests join instantly from their phones for a scrapbook-style collage.</p>

        <form class="card create-form" method="post" action="/events">
          <label for="code">Event code</label>
          <div class="row">
            <input id="code" name="code" type="text" value="{{ .DefaultCode }}" maxlength="24" autocomplete="off">
            <button type="submit">Create booth</button>
          </div>
          <p class="hint">Use letters, numbers, and dashes only.</p>
        </form>
      </div>

      <aside class="home-side">
        <div class="hero-note">
          <h2>Designed for the room</h2>
          <p>The board looks like real pinned prints, so it reads better on a larger display than a standard app grid.</p>
        </div>
        <div class="mini-note">
          <strong>Flow</strong>
          <p>Scan, snap, style, and watch each photo land on the wall live.</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="event-list">
    <div class="section-head">
      <h2>Recent events</h2>
      <a class="nav-link" href="/admin/demo">Open demo</a>
    </div>

    {{ if .Events }}
    <div class="grid cards">
      {{ range .Events }}
      <article class="card event-card">
        <h3>{{ .Code }}</h3>
        <p>Created {{ .CreatedAt.Format "2006-01-02 15:04 UTC" }}</p>
        <div class="actions">
          <a class="nav-link" href="/admin/{{ .Code }}">Admin</a>
          <a class="nav-link" href="/join/{{ .Code }}">Join</a>
          <a class="nav-link" href="/board/{{ .Code }}">Board</a>
        </div>
      </article>
      {{ end }}
    </div>
    {{ else }}
    <p class="card empty">No events yet.</p>
    {{ end }}
  </section>
</main>
</body>
</html>
{{ end }}
