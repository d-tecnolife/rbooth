{{ define "notfound" }}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body>
<button class="menu-scrim" type="button" data-nav-scrim aria-label="Close menu"></button>
<aside class="side-menu" aria-label="Site menu">
  <div class="side-menu-head">
    <div class="brand-block">
      <div class="brand-mark">rb</div>
      <div class="brand-copy">
        <strong>rbooth</strong>
        <span>photo board</span>
      </div>
    </div>
    <button type="button" data-nav-close>Close</button>
  </div>
  <div class="side-menu-links">
    <a class="nav-link" href="{{ .BoardURL }}">Photo board</a>
    <a class="nav-link" href="{{ .CaptureURL }}">Take a photo</a>
  </div>
  <div class="side-menu-meta">
    <div class="menu-note">This page is missing, but the board and camera flow are still one tap away.</div>
  </div>
</aside>

<main class="shell shell-board">
  <nav class="site-nav" aria-label="Primary">
    <div class="brand-block">
      <div class="brand-mark">rb</div>
      <div class="brand-copy">
        <strong>rbooth</strong>
        <span>live photo wall</span>
      </div>
    </div>
    <button class="nav-toggle" type="button" data-nav-open>Menu</button>
  </nav>

  <section class="board-shell">
    <div class="board-main">
      <section class="compact-panel notfound-panel">
        <div class="notfound-copy">
          <p class="eyebrow">404</p>
          <h1 class="compact-title">This page is not on the wall.</h1>
          <p class="compact-copy">The link you opened does not exist here. You can jump back to the photo board or head straight to the capture page.</p>
        </div>
        <div class="board-links notfound-actions">
          <a href="{{ .BoardURL }}">Go to photo board</a>
          <a href="{{ .CaptureURL }}">Open capture page</a>
        </div>
      </section>
    </div>

    <aside class="board-rail">
      <div>
        <p class="eyebrow">Quick capture</p>
        <img class="board-mini-qr" src="/qr" alt="QR code for opening the capture page">
      </div>
      <div class="board-note">
        <h2>Need to add a photo?</h2>
        <p>Scan the code or open the capture page, take a photo, then publish it straight onto the wall.</p>
      </div>
      <div class="board-links">
        <a href="{{ .CaptureURL }}">Open camera page</a>
      </div>
    </aside>
  </section>
</main>

<script src="/static/js/nav.js" defer></script>
</body>
</html>
{{ end }}
