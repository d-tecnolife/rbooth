{{ define "admin" }}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body>
<button class="menu-scrim" type="button" data-nav-scrim aria-label="Close menu"></button>
<aside class="side-menu" aria-label="Site menu">
  <div class="side-menu-head">
    <div class="brand-block">
      <div class="brand-mark">rb</div>
      <div class="brand-copy">
        <strong>rbooth</strong>
        <span>shared booth</span>
      </div>
    </div>
    <button type="button" data-nav-close>Close</button>
  </div>
  <div class="side-menu-links">
    <a class="nav-link" href="/">Home</a>
    <a class="nav-link" href="{{ .BoardURL }}">Photo wall</a>
    <a class="nav-link" href="{{ .CaptureURL }}">Take a photo</a>
  </div>
  <div class="side-menu-meta">
    <div class="menu-note">Host tools stay off the shared menu and only open from `/admin`.</div>
  </div>
</aside>

<main class="shell shell-admin">
  <nav class="site-nav" aria-label="Primary">
    <div class="brand-block">
      <div class="brand-mark">rb</div>
      <div class="brand-copy">
        <strong>rbooth</strong>
        <span>host tools</span>
      </div>
    </div>
    <button class="nav-toggle" type="button" data-nav-open>Menu</button>
  </nav>

  <section class="compact-panel">
    <div class="compact-grid">
      <div>
        <p class="eyebrow">Booth controls</p>
        <h1 class="compact-title">Keep the board running.</h1>
        <p class="compact-copy">Use this page for QR access, board links, and a quick status check while the photo wall stays on the main display.</p>
      </div>
      <div class="admin-actions">
        <a class="button-link" href="{{ .AccessURL }}">Open camera page</a>
        <a class="button-link" href="{{ .BoardURL }}">Open photo wall</a>
        <form action="/admin/logout" method="post">
          <button class="button-secondary" type="submit">Sign out</button>
        </form>
      </div>
    </div>
  </section>

  <section class="admin-grid">
    <article class="card info-card">
      <h2>QR and links</h2>
      <img class="qr-image" src="/qr" alt="QR code for the shared board capture page">
      <label>
        Capture URL
        <input type="text" value="{{ .AccessURL }}" readonly>
      </label>
      <label>
        Board URL
        <input type="text" value="{{ .BoardURL }}" readonly>
      </label>
    </article>

    <article class="card info-card">
      <h2>Quick snapshot</h2>
      <div class="admin-facts">
        <p><strong>Started:</strong> {{ .Event.CreatedAt.Format "2006-01-02 15:04 UTC" }}</p>
        <p><strong>Photos on wall:</strong> <span id="adminPhotoCount">{{ len .Photos }}</span></p>
        <p><strong>Guest flow:</strong> Scan, snap, style, publish.</p>
        <p><strong>Display tip:</strong> Keep the board on the biggest screen in the room.</p>
      </div>
    </article>
  </section>

  <section class="gallery-strip">
    <div class="section-head">
      <h2>Latest uploads</h2>
    </div>
    <div class="grid cards">
      {{ range .Photos }}
      <article class="card thumb-card" data-photo-id="{{ .ID }}">
        <img src="{{ .DisplayURL }}" alt="{{ .Caption }}">
        <div class="thumb-copy">
          <p>{{ if .Caption }}{{ .Caption }}{{ else }}Untitled photo{{ end }}</p>
          <p class="thumb-file">{{ .Filename }}</p>
        </div>
        <button class="button-link danger-button" type="button" data-delete-photo="{{ .ID }}">Delete {{ .ID }}</button>
      </article>
      {{ else }}
      <article id="adminEmptyState" class="card empty">
        <p>No photos yet. Open the camera page on a phone and publish one.</p>
      </article>
      {{ end }}
    </div>
  </section>
</main>

<script src="/static/js/nav.js" defer></script>
<script src="/static/js/admin.js" defer></script>
</body>
</html>
{{ end }}
