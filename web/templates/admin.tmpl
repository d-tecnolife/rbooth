{{ define "admin" }}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body>
<main class="shell shell-admin">
  <nav class="site-nav" aria-label="Primary">
    <div class="brand-block">
      <div class="brand-mark">rb</div>
      <div class="brand-copy">
        <strong>rbooth</strong>
        <span>host dashboard</span>
      </div>
    </div>
    <div class="nav-links">
      <a class="nav-link" href="{{ .BoardURL }}">Photo board</a>
      <a class="nav-link" href="{{ .JoinURL }}">Take a photo</a>
      <a class="nav-link nav-link-active" href="{{ .AdminURL }}">Host tools</a>
    </div>
  </nav>

  <section class="admin-panel">
    <div class="admin-header">
      <div>
        <p class="eyebrow">Booth controls</p>
        <h1>Host the board with style.</h1>
        <p>Keep the join link and QR code nearby, then leave the photo wall open on a larger screen so the collage keeps building through the event.</p>
      </div>
      <div class="admin-actions">
        <a class="button-link" href="{{ .JoinURL }}">Open camera page</a>
        <a class="button-link" href="{{ .BoardURL }}">Open photo wall</a>
      </div>
    </div>
  </section>

  <section class="admin-grid">
    <article class="card info-card">
      <h2>QR and links</h2>
      <img class="qr-image" src="/qr" alt="QR code for the shared board join page">
      <label>
        Join URL
        <input type="text" value="{{ .JoinURL }}" readonly>
      </label>
      <label>
        Board URL
        <input type="text" value="{{ .BoardURL }}" readonly>
      </label>
    </article>

    <article class="card info-card">
      <h2>Quick snapshot</h2>
      <div class="admin-facts">
        <p><strong>Started:</strong> {{ .Event.CreatedAt.Format "2006-01-02 15:04 UTC" }}</p>
        <p><strong>Photos on wall:</strong> {{ len .Photos }}</p>
        <p><strong>Guest flow:</strong> Scan, snap, style, publish.</p>
        <p><strong>Display tip:</strong> Keep the board open on the biggest screen in the room.</p>
      </div>
      <div class="board-note">
        <h2>Event mood</h2>
        <p>The shared board is styled like a pastel pinboard, so the best setup is a visible QR code next to the board display for a smooth loop.</p>
      </div>
    </article>
  </section>

  <section class="gallery-strip">
    <div class="section-head">
      <h2>Latest uploads</h2>
    </div>
    <div class="grid cards">
      {{ range .Photos }}
      <article class="card thumb-card">
        <img src="{{ .DisplayURL }}" alt="{{ .Caption }}">
        <p>{{ if .Caption }}{{ .Caption }}{{ else }}Untitled photo{{ end }}</p>
      </article>
      {{ else }}
      <article class="card empty">
        <p>No photos yet. Open the camera page on a phone and publish one.</p>
      </article>
      {{ end }}
    </div>
  </section>
</main>
</body>
</html>
{{ end }}
