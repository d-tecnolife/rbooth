{{ define "join" }}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }}</title>
  <link rel="stylesheet" href="/static/css/app.css">
</head>
<body>
<button class="menu-scrim" type="button" data-nav-scrim aria-label="Close menu"></button>
<aside class="side-menu" aria-label="Site menu">
  <div class="side-menu-head">
    <div class="brand-block">
      <div class="brand-mark">rb</div>
      <div class="brand-copy">
        <strong>rbooth</strong>
        <span>capture and publish</span>
      </div>
    </div>
    <button type="button" data-nav-close>Close</button>
  </div>
  <div class="side-menu-links">
    <a class="nav-link" href="{{ .BoardURL }}">Photo board</a>
    <a class="nav-link nav-link-active" href="{{ .JoinURL }}">Take a photo</a>
    <a class="nav-link" href="{{ .AdminURL }}">Host tools</a>
  </div>
  <div class="side-menu-meta">
    <div class="menu-note">The join page keeps instructions compact so the camera and controls stay dominant.</div>
  </div>
</aside>

<main class="shell shell-join">
  <nav class="site-nav" aria-label="Primary">
    <div class="brand-block">
      <div class="brand-mark">rb</div>
      <div class="brand-copy">
        <strong>rbooth</strong>
        <span>take a photo</span>
      </div>
    </div>
    <button class="nav-toggle" type="button" data-nav-open>Menu</button>
  </nav>

  <section class="compact-panel">
    <div class="compact-grid">
      <div>
        <p class="eyebrow">Join the booth</p>
        <h1 class="compact-title">Snap, style, publish.</h1>
        <p class="compact-copy">Use the camera or upload a shot, make quick edits, and send it to the board without leaving the browser.</p>
      </div>
      <div class="mini-chips">
        <span>1. Capture</span>
        <span>2. Style</span>
        <span>3. Publish</span>
      </div>
    </div>
  </section>

  <section class="join-layout">
    <div class="card preview-card">
      <div class="camera-stack">
        <video id="camera" autoplay playsinline muted></video>
        <canvas id="preview" width="1080" height="1080" hidden></canvas>
        <div id="previewFrame" class="preview-frame" hidden></div>
      </div>

      <div class="capture-actions">
        <button id="startCamera" type="button">Enable camera</button>
        <button id="capturePhoto" type="button" disabled>Capture</button>
        <button id="retakePhoto" type="button" disabled>Retake</button>
        <label class="upload-fallback">
          <span>Upload file</span>
          <input id="uploadInput" type="file" accept="image/*">
        </label>
      </div>
    </div>

    <form id="uploadForm" class="card controls-card">
      <h2>Style your print</h2>
      <div class="join-guide">
        <ol>
          <li>Frame the shot.</li>
          <li>Adjust the look.</li>
          <li>Publish to the wall.</li>
        </ol>
      </div>

      <label>
        Caption
        <input type="text" name="caption" maxlength="60" placeholder="Optional caption">
      </label>

      <label>
        Brightness
        <input type="range" name="brightness" min="60" max="140" value="100">
      </label>

      <label>
        Contrast
        <input type="range" name="contrast" min="60" max="150" value="100">
      </label>

      <label>
        Saturation
        <input type="range" name="saturation" min="0" max="160" value="100">
      </label>

      <label>
        Grayscale
        <input type="range" name="grayscale" min="0" max="100" value="0">
      </label>

      <label>
        Tone
        <select name="tone">
          <option value="neutral">Neutral</option>
          <option value="warm">Warm</option>
          <option value="cool">Cool</option>
          <option value="party">Party</option>
        </select>
      </label>

      <label>
        Backdrop
        <select name="backdrop">
          <option value="sunrise">Sunrise</option>
          <option value="mint">Mint</option>
          <option value="night">Night</option>
          <option value="paper">Paper</option>
        </select>
      </label>

      <button id="publishPhoto" type="submit" disabled>Publish to board</button>
      <p id="statusMessage" class="status">Enable the camera or upload a file to begin.</p>
      <p class="hint">No app install required.</p>
    </form>
  </section>
</main>

<script src="/static/js/nav.js" defer></script>
<script src="/static/js/join.js" defer></script>
</body>
</html>
{{ end }}
